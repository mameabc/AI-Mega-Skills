{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-mega-skills/skill-manifest.schema.json",
  "title": "AI Mega Skills Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "description",
    "domain",
    "subdomain",
    "version",
    "owners",
    "tags",
    "inputs",
    "outputs",
    "validation",
    "license",
    "status"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "subdomain": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string",
      "default": "MIT"
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "experimental", "stable", "deprecated"]
    }
  }
}

